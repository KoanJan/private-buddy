# Private Buddy Environment Variables
# Copy this file to .env and modify as needed

# Data root directory (default: ~/PBD_trial_docker_and_embedding)
DATA_ROOT=~/PBD_trial_docker_and_embedding

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Summary window size for context management
SUMMARY_WINDOW_SIZE=5

# Task execution settings
TASK_MAX_ITERATIONS=50
CONTEXT_WINDOW_ITERATIONS=10
NOTES_MAX_CHARS=5000

# Network settings (optional)
# If you need to use a proxy for LLM API calls, uncomment and configure:
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=http://proxy.example.com:8080
# NO_PROXY=localhost,127.0.0.1

# DNS settings (optional, for Docker containers)
# If containers cannot resolve external domains, uncomment and configure:
# DNS_SERVER=8.8.8.8