;; private-buddy Seatbelt sandbox policy
;; Design: availability over security. Restrict writes only;
;; everything else (reads, execution, network) is allowed by default.
;; mach-lookup is NOT covered by (allow default) and must be listed explicitly.
(version 1)
(allow default)

;; === Mach IPC: DNS resolution and network configuration ===
;; (allow default) does not cover mach-lookup. Without these rules,
;; DNS resolution via mDNSResponder fails, breaking all network access.
(allow mach-lookup
    (global-name "com.apple.mDNSResponder")
    (global-name "com.apple.mDNSResponder.service")
    (global-name "com.apple.SystemConfiguration.configd")
)

;; === Write: deny protected directories ===
(deny file-write*
    (subpath "/private/etc")
    (subpath "/private/var/log")
    (subpath "/private/var/db")
    (subpath "/private/var/run")
    (subpath "/usr")
    (subpath "/System")
    (subpath "/Library")
    (subpath "/Applications")
    (regex #"^/Users/[^/]+/\.(ssh|gnupg|aws)")
)

;; === Write: only workspace and temp directories ===
(allow file-write*
    (subpath "$WORKSPACE")
    (subpath "/private/tmp")
    (subpath "/private/var/folders")
)
(allow file-write*
    (literal "/dev/null")
    (literal "/dev/stdin")
    (literal "/dev/stdout")
    (literal "/dev/stderr")
    (literal "/dev/dtracehelper")
)
